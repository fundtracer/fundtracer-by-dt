{
    "name": "@fundtracer/server",
    "version": "1.0.2",
    "description": "FundTracer API Server - Handles auth, rate limiting, and secure API key management",
    "main": "dist/mcp/stdio.js",
    "bin": {
        "fundtracer-mcp": "dist/mcp/stdio.js"
    },
    "scripts": {
        "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --external:esbuild --outfile=dist/index.js 2>/dev/null; esbuild src/mcp/stdio.ts --bundle --platform=node --target=node18 --format=cjs --external:fundtracer-core --external:axios --external:dotenv --external:node-fetch --external:firebase-admin --external:ethers --external:express --external:groq --external:openai --external:telegraf --external:qrcode --external:speakeasy --external:helmet --external:cors --external:cheerio --external:bcryptjs --external:jsonwebtoken --external:@upstash/redis --external:@cfworker/json-schema --external:@modelcontextprotocol --external:@lemonsqueezy --external:nodemailer --external:resend --external:serverless-http --external:express-rate-limit --external:finalhandler --external:encoding --external:on-finished --external:statuses --external:encodeurl --external:@types/jsonwebtoken --external:@types/nodemailer --outfile=dist/mcp/stdio.js",
        "start": "node dist/index.js",
        "dev": "tsx watch src/index.ts",
        "mcp": "tsx src/mcp/stdio.ts",
        "mcp:start": "node dist/mcp/stdio.js",
        "build:mcp": "esbuild src/mcp/stdio.ts --bundle --platform=node --target=node18 --format=esm --external:fundtracer-core --external:@modelcontextprotocol/server --external:firebase-admin --external:dotenv --external:node-fetch --external:axios --external:ethers --external:express --external:groq --external:openai --external:telegraf --external:qrcode --external:speakeasy --external:helmet --external:cors --external:cheerio --external:bcryptjs --external:jsonwebtoken --external:@upstash/redis --external:@cfworker/json-schema --external:@lemonsqueezy --external:nodemailer --external:resend --external:serverless-http --external:express-rate-limit --external:finalhandler --external:encoding --external:on-finished --external:statuses --external:encodeurl --external:../firebase.js --external:../models/apiKey.js --outfile=mcp-publish/fundtracer-mcp.js"
    },
    "dependencies": {
        "@cfworker/json-schema": "^4.1.1",
        "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
        "@modelcontextprotocol/express": "^2.0.0-alpha.2",
        "@modelcontextprotocol/node": "^2.0.0-alpha.2",
        "@modelcontextprotocol/server": "^2.0.0-alpha.2",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/nodemailer": "^7.0.11",
        "@upstash/redis": "^1.34.0",
        "bcryptjs": "^2.4.3",
        "cheerio": "^1.1.2",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "encodeurl": "^2.0.0",
        "encoding": "^0.1.13",
        "ethers": "^6.16.0",
        "express": "^4.22.2",
        "express-rate-limit": "^7.5.1",
        "finalhandler": "^1.3.2",
        "firebase-admin": "^12.0.0",
        "fundtracer-core": "^1.0.3",
        "groq": "^3.99.0",
        "helmet": "^7.2.0",
        "jsonwebtoken": "^9.0.3",
        "node-fetch": "^2.7.0",
        "nodemailer": "^6.10.1",
        "on-finished": "^2.4.1",
        "openai": "^6.37.0",
        "qrcode": "^1.5.4",
        "resend": "^6.9.3",
        "serverless-http": "^4.0.0",
        "speakeasy": "^2.0.0",
        "statuses": "^2.0.2",
        "telegraf": "^4.16.3"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.0",
        "@types/qrcode": "^1.5.5",
        "esbuild": "^0.21.5",
        "tsx": "^4.7.0",
        "typescript": "^5.3.0"
    }
}
